
generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

enum TransactionType {
  Income
  Expense
}

enum SavingType {
  Fixed
  Fun
  Saving
}

enum Owner {
  Alex
  Casey
  Joint
}

enum ClubType {
  Driver
  Wood
  Hybrid
  Iron
  Wedge
  Putter
}

enum SwingLength {
  Full
  Shoulder
  Chest
  Hip
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  owner         Owner?    // which person (Alex/Casey) this login represents
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  image         String?
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Category {
  id             String        @id @default(cuid())
  name           String        @unique
  color          String
  savingType     SavingType    @default(Fun)
  transactions   Transaction[]
}

model Transaction {
  id               String          @id @default(cuid())
  description      String
  amount           Decimal
  type             TransactionType
  date             DateTime        @default(now())
  createdAt        DateTime        @default(now())
  categoryId       String
  category         Category        @relation(fields: [categoryId], references: [id])
  externalId       String?         @unique
  note             String?
  owner            Owner           @default(Joint)
  reviewed         Boolean         @default(false)
  excludeFromSavings Boolean       @default(false)
  savingType       SavingType?     // per-transaction override; null = inherit from category
  originalAmount   Decimal?
  originalCurrency String?
}

model Club {
  id        String     @id @default(cuid())
  name      String     @unique // "Driver", "5 Wood", "Hybrid", "4 Iron", ..., "52°", "56°", "60°", "Putter"
  type      ClubType
  sortOrder Int        @default(0)
  distances Distance[]

  @@map("club")
}

// A club's carry yardage at a given swing length. Full-swing clubs (irons,
// woods, driver) only ever have a "Full" row; wedges also get partial-swing
// rows (Shoulder/Chest/Hip) for the gapping matrix.
model Distance {
  id        String      @id @default(cuid())
  clubId    String
  club      Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  swing     SwingLength @default(Full)
  yards     Int
  updatedAt DateTime    @updatedAt

  @@unique([clubId, swing])
  @@map("distance")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
