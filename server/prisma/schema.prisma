
generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

enum ClubType {
  Driver
  Wood
  Hybrid
  Iron
  Wedge
  Putter
}

enum SwingLength {
  Full
  Shoulder
  Chest
  Hip
}

enum DistanceUnit {
  Yards
  Metres
}

enum TeeColour {
  Yellow
  White
  Red
  Blue
}

// The kind of shot a swing thought is for. Deliberately its own enum, not
// ClubType — a shot you play, not an implement in the bag. Pitch, Chip and
// Bunker are shots with no club of their own. See docs/adr/0002.
enum ShotType {
  Driver
  Iron
  Pitch
  Chip
  Putt
  Bunker
}

// Where in the motion a swing thought applies. Unrelated to SwingLength, which
// is the depth of a wedge's backswing, not a moment in the stroke.
enum SwingPhase {
  Setup
  Backswing
  Downswing
  Finish
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  image         String?
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Club {
  id        String     @id @default(cuid())
  name      String     @unique // "Driver", "5 Wood", "Hybrid", "4 Iron", ..., "52°", "56°", "60°", "Putter"
  type      ClubType
  sortOrder Int        @default(0)
  // Whether this club is currently in the 14-club bag vs. benched. Clubs are
  // never hard-deleted — swapping a club out just flips this to false so its
  // distance history is kept for whenever it comes back in.
  isActive  Boolean    @default(true)
  distances Distance[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  @@map("clubs")
}

// A club's carry yardage at a given swing length. Full-swing clubs (irons,
// woods, driver) only ever have a "Full" row; wedges also get partial-swing
// rows (Shoulder/Chest/Hip) for the gapping matrix.
model Distance {
  id         String       @id @default(cuid())
  clubId     String
  club       Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  swing      SwingLength  @default(Full)
  yards      Int
  unit       DistanceUnit @default(Yards)
  // The day this yardage was actually measured/verified (range session, not
  // edit time — see updatedAt for that). Backfilled to 2026-07-19 for rows
  // that predate this column.
  measuredAt DateTime     @default(now())
  createdAt   DateTime    @default(now())
  updatedAt  DateTime     @updatedAt
  createdById String?
  updatedById String?

  @@unique([clubId, swing])
  @@map("distances")
}

// Snapshot of a distance's previous yards value, written by a DB trigger
// (see migration 20260720000000_distance_history) every time "distances.yards"
// changes. Prisma never writes here directly — read-only from the app's side.
model DistanceHistory {
  id         Int      @id @default(autoincrement())
  distanceId String
  clubId     String
  swing      SwingLength
  yards      Int
  changedAt  DateTime @default(now())

  @@map("distance_history")
}

// One 18-hole layout. Richmond Park is two Courses (Duke's, Prince's), not one.
model Course {
  id        String   @id @default(cuid())
  name      String   @unique // "Duke's", "Prince's", "Toot Hill"
  // The club/site this course belongs to. Richmond Park holds Duke's and
  // Prince's; Toot Hill Golf Club holds one. Groups the course picker.
  venue     String   @default("Richmond Park")
  sortOrder Int      @default(0)
  holes     Hole[]
  teeSets   TeeSet[]
  rounds    Round[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  @@map("courses")
}

// A numbered hole, identified by its green. Everything here is course-wide —
// anything that varies by which tees you play lives on HoleTee instead.
model Hole {
  id       String @id @default(cuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  number   Int

  // The green's outline as a JSON array of [lat, lng] pairs, imported from
  // OpenStreetMap. Front/middle/back are all derived from this — the outline
  // and the centroid below must always describe the same green, which is why
  // the editor reassigns whole outlines rather than dragging the centre pin.
  greenPolygon String?
  greenLat     Float?
  greenLng     Float?

  // A chosen spot the hole is played through: a dogleg corner or a layup
  // target. Set by dragging the marker on /gps; persists between rounds.
  aimLat Float?
  aimLng Float?

  tees   HoleTee[]
  scores HoleScore[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  @@unique([courseId, number])
  @@map("holes")
}

// A course played from one set of tee markers. Par and stroke index belong
// here, not on Hole — Duke's 17th is a par 5 off white and a par 4 off yellow.
model TeeSet {
  id       String    @id @default(cuid())
  courseId String
  course   Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  colour   TeeColour
  name     String // "Men's Yellow"
  holes    HoleTee[]
  players  Player[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  @@unique([courseId, colour])
  @@map("tee_sets")
}

// One hole as played from one tee set. Coordinates are nullable: the yellow
// set has them, the others carry scorecard numbers only until someone places
// their tee boxes.
model HoleTee {
  id          String @id @default(cuid())
  holeId      String
  hole        Hole   @relation(fields: [holeId], references: [id], onDelete: Cascade)
  teeSetId    String
  teeSet      TeeSet @relation(fields: [teeSetId], references: [id], onDelete: Cascade)
  yards       Int
  par         Int
  strokeIndex Int
  teeLat      Float?
  teeLng      Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  @@unique([holeId, teeSetId])
  @@map("hole_tees")
}

// One trip round a course by a group of up to four players. The id is minted on
// the phone, not here: the round is played offline in localStorage and pushed up
// whole, so it needs an identity before the server has ever heard of it. The tee
// set is per-Player, not per-Round — a mixed fourball plays off different tees on
// the same card (see ADR 0001).
model Round {
  id          String    @id
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  playedOn    DateTime  @default(now())
  // Null while the round is still in play. An abandoned nine stays a round.
  completedAt DateTime?
  players     Player[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  updatedById String?
  // Rounds are soft-deleted, never removed: a mis-tap on the course is
  // recoverable. Read paths filter deletedAt IS NULL.
  deletedAt   DateTime?
  deletedById String?

  @@index([playedOn])
  @@map("rounds")
}

// One person on a round's card — one to four of them. Player 1 is always you,
// permanent, and cannot be removed; guests 2–4 are removable. Carries the tee set
// this player used and their own hole scores. userId is reserved for future
// account-linking (ADR 0001) and is unused today.
model Player {
  id       String @id
  roundId  String
  round    Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  // 1–4. Player 1 is you.
  position Int
  name     String
  teeSetId String
  teeSet   TeeSet @relation(fields: [teeSetId], references: [id], onDelete: Restrict)
  userId   String?
  scores   HoleScore[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  updatedById String?
  deletedAt   DateTime?
  deletedById String?

  @@unique([roundId, position])
  @@map("players")
}

// What one hole cost one player in one round. Strokes are gross — no handicap is
// applied anywhere in this app. Putts are optional (kept for Player 1 in
// practice), and are what make green-in-regulation derivable rather than another
// thing to tap.
model HoleScore {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  holeId   String
  hole     Hole   @relation(fields: [holeId], references: [id], onDelete: Cascade)
  strokes  Int
  putts    Int?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  updatedById String?
  deletedAt   DateTime?
  deletedById String?

  @@unique([playerId, holeId])
  @@map("hole_scores")
}

// One cue held in mind for a kind of shot. Filed under exactly one ShotType
// and one SwingPhase; rank orders it within its ShotType (highest first). The
// same cue wanted for two shots is two rows, ranked independently.
model SwingThought {
  id        String     @id @default(cuid())
  shotType  ShotType
  phase     SwingPhase
  // 0–100, how much this is worth thinking about. Sorted desc within a ShotType.
  rank      Int
  text      String
  note      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  createdById String?
  updatedById String?

  @@index([shotType, rank])
  @@map("swing_thoughts")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
