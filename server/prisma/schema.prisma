
generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

enum TransactionType {
  Income
  Expense
}

enum SavingType {
  Fixed
  Fun
  Saving
}

enum Owner {
  Alex
  Casey
  Joint
}

enum TabDirection {
  IOwe
  TheyOwe
}

enum TabStatus {
  Open
  Settled
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  owner         Owner?    // which person (Alex/Casey) this login represents
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  image         String?
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Category {
  id             String        @id @default(cuid())
  name           String        @unique
  color          String
  savingType     SavingType    @default(Fun)
  transactions   Transaction[]
  categoryRules  CategoryRule[]
}

// Auto-categorize rule: a description pattern (optionally scoped to a bank)
// that maps to a category. Applied during /process and backfilled on create.
model CategoryRule {
  id         String   @id @default(cuid())
  pattern    String
  bank       String?
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([pattern, bank])
}

model Transaction {
  id               String          @id @default(cuid())
  description      String
  amount           Decimal
  type             TransactionType
  date             DateTime        @default(now())
  createdAt        DateTime        @default(now())
  categoryId       String
  category         Category        @relation(fields: [categoryId], references: [id])
  externalId       String?         @unique
  note             String?
  owner            Owner           @default(Joint)
  reviewed         Boolean         @default(false)
  excludeFromSavings Boolean       @default(false)
  savingType       SavingType?     // per-transaction override; null = inherit from category
  originalAmount   Decimal?
  originalCurrency String?
}

// One staging model per bank — each preserves that bank's raw CSV schema exactly.
// The process step normalises all of them into the shared Transaction model.

// Monzo: synced directly from the Monzo Developer API, covering both the
// uk_retail (debit) and uk_monzo_flex (Flex credit card) accounts.
// Fields mirror the API response — no CSV quirks.
model MonzoApiTransaction {
  id                 String    @id @default(cuid())
  monzoId            String    @unique          // tx_xxx from the API
  created            DateTime
  settled            DateTime?
  amountPence        Int                        // pence; negative = expense
  currency           String
  localAmountPence   Int
  localCurrency      String
  description        String                     // Monzo raw description field
  notes              String?
  monzoCategory      String                     // raw slug e.g. "eating_out"
  merchantName       String?
  merchantEmoji      String?
  merchantAddress    String?
  scheme             String?
  includeInSpending  Boolean
  accountId          String
  importedAt         DateTime  @default(now())
  status             String    @default("pending")

  @@map("monzo_api_transaction")
}

model PlaidItem {
  id          String   @id @default(cuid())
  userId      String   @unique
  accessToken String
  itemId      String   @unique
  cursor      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("plaid_item")
}

model PlaidTransaction {
  id            String   @id @default(cuid())
  transactionId String   @unique
  date          String
  description   String
  amount        Float
  currency      String
  merchantName  String?
  owner         String   @default("Alex")
  importedAt    DateTime @default(now())
  status        String   @default("pending")

  @@map("plaid_transaction")
}

model MonzoCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  accountId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("monzo_credential")
}

model AmexTransaction {
  transactionId   String   @id
  transactionDate String
  processDate     String
  description     String
  amount          String
  isCredit        Boolean  @default(false)
  foreignCurrency String?
  foreignAmount   String?
  statementDate   String
  owner           String   @default("Alex")
  importedAt      DateTime @default(now())
  status          String   @default("pending")

  @@map("amex_transaction")
}

model BarclaysTransaction {
  id            Int      @id @default(autoincrement())
  transactionId String?  @unique
  date          String
  description   String
  amount        String
  isCredit      Boolean  @default(false)
  statementDate String
  owner         String   @default("Alex")
  importedAt    DateTime @default(now())
  status        String   @default("pending")

  @@map("barclays_transaction")
}

model SantanderTransaction {
  id            Int      @id @default(autoincrement())
  transactionId String?  @unique
  date          String
  description   String
  moneyIn       String?
  moneyOut      String?
  balance       String
  statementDate String
  owner         String   @default("Alex")
  importedAt    DateTime @default(now())
  status        String   @default("pending")

  @@map("santander_transaction")
}

model HsbcTransaction {
  id            Int      @id @default(autoincrement())
  transactionId String   @unique
  date          String
  paymentType   String
  description   String
  moneyOut      String?
  moneyIn       String?
  balance       String?
  statementDate String
  owner         String   @default("Joint")
  importedAt    DateTime @default(now())
  status        String   @default("pending")

  @@map("hsbc_transaction")
}

model ChaseTransaction {
  id            Int      @id @default(autoincrement())
  transactionId String   @unique
  date          String
  description   String
  amount        String
  isCredit      Boolean  @default(false)
  statementDate String
  owner         String   @default("Casey")
  importedAt    DateTime @default(now())
  status        String   @default("pending")

  @@map("chase_transaction")
}

model SofiTransaction {
  id            Int      @id @default(autoincrement())
  transactionId String   @unique
  date          String
  type          String
  description   String
  amount        String
  isCredit      Boolean  @default(false)
  balance       String?
  accountType   String   @default("Checking")
  statementDate String
  owner         String   @default("Casey")
  importedAt    DateTime @default(now())
  status        String   @default("pending")

  @@map("sofi_transaction")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  body      String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("note")
}

model Tab {
  id          String       @id @default(cuid())
  person      String
  description String
  amount      Decimal
  direction   TabDirection
  status      TabStatus    @default(Open)
  dueDate     DateTime?
  settledAt   DateTime?
  note        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tab")
}

model InvestmentAccount {
  id        String   @id @default(cuid())
  name      String
  category  String   // pension | crypto | equity | cash | commodity | debt
  owner     Owner    @default(Alex)
  rate      Float?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots InvestmentSnapshot[]

  @@unique([owner, name])
  @@map("investment_account")
}

model InvestmentSnapshot {
  id        String            @id @default(cuid())
  accountId String
  date      DateTime
  value     Float
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  account   InvestmentAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@map("investment_snapshot")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
