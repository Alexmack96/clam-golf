generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

enum ClubType {
  Driver
  Wood
  Hybrid
  Iron
  Wedge
  Putter
}

enum SwingLength {
  Full
  Shoulder
  Chest
  Hip
}

enum DistanceUnit {
  Yards
  Metres
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  image     String?
  sessions  Session[]
  accounts  Account[]

  @@map("user")
}

model Club {
  id        String     @id @default(cuid())
  name      String     @unique // "Driver", "5 Wood", "Hybrid", "4 Iron", ..., "52°", "56°", "60°", "Putter"
  type      ClubType
  sortOrder Int        @default(0)
  // Whether this club is currently in the 14-club bag vs. benched. Clubs are
  // never hard-deleted — swapping a club out just flips this to false so its
  // distance history is kept for whenever it comes back in.
  isActive  Boolean    @default(true)
  distances Distance[]

  @@map("clubs")
}

// A club's carry yardage at a given swing length. Full-swing clubs (irons,
// woods, driver) only ever have a "Full" row; wedges also get partial-swing
// rows (Shoulder/Chest/Hip) for the gapping matrix.
model Distance {
  id         String       @id @default(cuid())
  clubId     String
  club       Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  swing      SwingLength  @default(Full)
  yards      Int
  unit       DistanceUnit @default(Yards)
  // The day this yardage was actually measured/verified (range session, not
  // edit time — see updatedAt for that). Backfilled to 2026-07-19 for rows
  // that predate this column.
  measuredAt DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([clubId, swing])
  @@map("distances")
}

// Snapshot of a distance's previous yards value, written by a DB trigger
// (see migration 20260720000000_distance_history) every time "distances.yards"
// changes. Prisma never writes here directly — read-only from the app's side.
model DistanceHistory {
  id         Int         @id @default(autoincrement())
  distanceId String
  clubId     String
  swing      SwingLength
  yards      Int
  changedAt  DateTime    @default(now())

  @@map("distance_history")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
